				################################################################
				# [#169 fix] Inline GREAT GAME strip. When the Qing player views a
				# Great Power (GBR/FRA/RUS) the diplomatic-range modifier surfaces,
				# show that power's rivalry TENSION + diplomatic STANDING inline in
				# the Diplomatic tab. Mirrors gui/qing_greatgame.gui's per-power
				# sections but reads DiplomaticView.GetTargetCountry for gating so it
				# is target-generic. Tension vars are a fixed per-power set
				# (qing_gp_tension_britain/_france/_russia), hence three tag-gated
				# sub-blocks. No player-clickable GP verbs exist (the provoke effects
				# fire from colonization/frontier events, not scripted GUIs), so the
				# strip is informational: tension + standing only.
				################################################################
				flowcontainer = {
					direction = vertical
					margin = { 10 6 }
					spacing = 6
					ignoreinvisible = yes
					visible = "[And( EqualTo_string( Player.GetTag, 'CHI' ), Or( EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'GBR' ), Or( EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'FRA' ), EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'RUS' ) ) ) )]"
					using = background_widget
					textbox = {
						autoresize = yes
						using = BaseFontM
						using = Default_FontColor
						text = "QING_GREAT_GAME_INLINE_HEADER"
					}
					# [#165] Sphere-of-influence tally: how the contested frontier marches
					# currently split between China and the three European powers. Reads the
					# per-power counts CHI recomputes each yearly sphere pulse (0 until the
					# first pulse). Informational; loc resolves the four |0-guarded counters.
					textbox = {
						autoresize = yes
						using = BaseFontS
						using = Default_FontColor
						text = "QING_SPHERE_INLINE_TALLY"
						tooltip = "QING_SPHERE_INLINE_TALLY_TT"
					}
					# --- GBR ---
					flowcontainer = {
						visible = "[EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'GBR' )]"
						direction = vertical
						spacing = 4
						layoutpolicy_horizontal = expanding
						# Tension bar
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_TENSION_LABEL"
								tooltip = "GREAT_GAME_TENSION_TT"
							}
							# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
							# up under the Standing value column instead of floating past the bar's right end.
							textbox = {
								size = { 40 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[Player.MakeScope.GetVariable('qing_gp_tension_britain').GetValue|0]"
							}
							progressbar = {
								using = progressbar_flat_green
								size = { 240 12 }
								value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_britain').GetValue, '(CFixedPoint)0.01' ) )]"
							}
						}
						# Standing (opinion)
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_STANDING_LABEL"
								tooltip = "GREAT_GAME_STANDING_TT"
							}
							textbox = {
								size = { 240 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[DiplomaticView.GetTargetCountry.GetOpinionOf(Player.GetCountry)|+=]"
							}
						}
					}
					# --- FRA ---
					flowcontainer = {
						visible = "[EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'FRA' )]"
						direction = vertical
						spacing = 4
						layoutpolicy_horizontal = expanding
						# Tension bar
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_TENSION_LABEL"
								tooltip = "GREAT_GAME_TENSION_TT"
							}
							# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
							# up under the Standing value column instead of floating past the bar's right end.
							textbox = {
								size = { 40 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[Player.MakeScope.GetVariable('qing_gp_tension_france').GetValue|0]"
							}
							progressbar = {
								using = progressbar_flat_green
								size = { 240 12 }
								value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_france').GetValue, '(CFixedPoint)0.01' ) )]"
							}
						}
						# Standing (opinion)
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_STANDING_LABEL"
								tooltip = "GREAT_GAME_STANDING_TT"
							}
							textbox = {
								size = { 240 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[DiplomaticView.GetTargetCountry.GetOpinionOf(Player.GetCountry)|+=]"
							}
						}
					}
					# --- RUS ---
					flowcontainer = {
						visible = "[EqualTo_string( DiplomaticView.GetTargetCountry.GetTag, 'RUS' )]"
						direction = vertical
						spacing = 4
						layoutpolicy_horizontal = expanding
						# Tension bar
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_TENSION_LABEL"
								tooltip = "GREAT_GAME_TENSION_TT"
							}
							# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
							# up under the Standing value column instead of floating past the bar's right end.
							textbox = {
								size = { 40 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[Player.MakeScope.GetVariable('qing_gp_tension_russia').GetValue|0]"
							}
							progressbar = {
								using = progressbar_flat_green
								size = { 240 12 }
								value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_russia').GetValue, '(CFixedPoint)0.01' ) )]"
							}
						}
						# Standing (opinion)
						flowcontainer = {
							spacing = 8
							textbox = {
								size = { 80 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "GREAT_GAME_STANDING_LABEL"
								tooltip = "GREAT_GAME_STANDING_TT"
							}
							textbox = {
								size = { 240 20 }
								using = BaseFontS
								using = Default_FontColor
								text = "[DiplomaticView.GetTargetCountry.GetOpinionOf(Player.GetCountry)|+=]"
							}
						}
					}
				}
			}
				################################################################
				# [#169] GREAT GAME view — combined four-power rivalry board.
				# Qing (player) vs Britain / France / Russia, all at once. Mirrors
				# gui/qing_greatgame.gui's per-power sections (tension + standing)
				# but lives inline as a diplomatic-view tab so it opens without a
				# separate window. Gated to the Qing player + the 'greatgame' tab.
				################################################################
				flowcontainer = {
					direction = vertical
					margin = { 10 10 }
					spacing = 10
					ignoreinvisible = yes
					visible = "[And( EqualTo_string( Player.GetTag, 'CHI' ), GetVariableSystem.HasValue( 'diplomatic_tabs', 'greatgame' ) )]"
					# Intro
					textbox = {
						size = { 460 72 }
						multiline = yes
						autoresize = no
						using = BaseFontM
						using = Default_FontColor
						text = "GREAT_GAME_PANEL_DESC"
					}
					# QING (self) header
					flowcontainer = {
						spacing = 8
						using = background_widget
						margin = { 8 8 }
						new_country_flag = {
							# [R2 error.log fix] was datacontext = "[Player.GetCountry]", which the engine
							# could not convert to a datacontext (error.log: diplomatic_view.gui:2061 Failed
							# converting property 'datacontext'). The proven form for a flag inside this view
							# is DiplomaticView.GetPlayer (upstream MIUNO, same file line 1017, works).
							datacontext = "[DiplomaticView.GetPlayer]"
							blockoverride "Size" { size = { 40 40 } }
							blockoverride "Flag" {
								texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
								frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
								framesize = { 56 56 }
							}
						}
						textbox = {
							size = { 340 28 }
							using = BaseFontM
							using = Default_FontColor
							text = "QING_GREAT_GAME_SELF_TITLE"
						}
					}
						# GBR SECTION
						flowcontainer = {
							visible = "[GetScriptedGui('qing_greatgame_britain_exists').IsShown( GuiScope.SetRoot( Player.MakeScope ).End )]"
							direction = vertical
							spacing = 4
							layoutpolicy_horizontal = expanding
							using = background_widget
							margin = { 8 8 }
							# title + flag
							flowcontainer = {
								spacing = 8
								new_country_flag = {
									datacontext = "[GetCountry('GBR')]"
									blockoverride "Size" { size = { 40 40 } }
									blockoverride "Flag" {
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
								}
								textbox = {
									size = { 300 28 }
									using = BaseFontM
									using = Default_FontColor
									text = "GREAT_GAME_BRITAIN_TITLE"
								}
							}
							# Tension bar
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_TENSION_LABEL"
									tooltip = "GREAT_GAME_TENSION_TT"
								}
								# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
								# up under the Standing value column instead of floating past the bar's right end.
								textbox = {
									size = { 40 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "[Player.MakeScope.GetVariable('qing_gp_tension_britain').GetValue|0]"
								}
								progressbar = {
									using = progressbar_flat_green
									size = { 240 12 }
									value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_britain').GetValue, '(CFixedPoint)0.01' ) )]"
								}
							}
							# Standing (opinion)
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_STANDING_LABEL"
									tooltip = "GREAT_GAME_STANDING_TT"
								}
								textbox = {
									size = { 240 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "[GetCountry('GBR').GetOpinionOf(Player.GetCountry)|+=]"
								}
							}
						}
						# FRA SECTION
						flowcontainer = {
							visible = "[GetScriptedGui('qing_greatgame_france_exists').IsShown( GuiScope.SetRoot( Player.MakeScope ).End )]"
							direction = vertical
							spacing = 4
							layoutpolicy_horizontal = expanding
							using = background_widget
							margin = { 8 8 }
							# title + flag
							flowcontainer = {
								spacing = 8
								new_country_flag = {
									datacontext = "[GetCountry('FRA')]"
									blockoverride "Size" { size = { 40 40 } }
									blockoverride "Flag" {
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
								}
								textbox = {
									size = { 300 28 }
									using = BaseFontM
									using = Default_FontColor
									text = "GREAT_GAME_FRANCE_TITLE"
								}
							}
							# Tension bar
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_TENSION_LABEL"
									tooltip = "GREAT_GAME_TENSION_TT"
								}
								# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
								# up under the Standing value column instead of floating past the bar's right end.
								textbox = {
									size = { 40 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "[Player.MakeScope.GetVariable('qing_gp_tension_france').GetValue|0]"
								}
								progressbar = {
									using = progressbar_flat_green
									size = { 240 12 }
									value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_france').GetValue, '(CFixedPoint)0.01' ) )]"
								}
							}
							# Standing (opinion)
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_STANDING_LABEL"
									tooltip = "GREAT_GAME_STANDING_TT"
								}
								textbox = {
									size = { 240 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "[GetCountry('FRA').GetOpinionOf(Player.GetCountry)|+=]"
								}
							}
						}
						# RUS SECTION
						flowcontainer = {
							visible = "[GetScriptedGui('qing_greatgame_russia_exists').IsShown( GuiScope.SetRoot( Player.MakeScope ).End )]"
							direction = vertical
							spacing = 4
							layoutpolicy_horizontal = expanding
							using = background_widget
							margin = { 8 8 }
							# title + flag
							flowcontainer = {
								spacing = 8
								new_country_flag = {
									datacontext = "[GetCountry('RUS')]"
									blockoverride "Size" { size = { 40 40 } }
									blockoverride "Flag" {
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
										framesize = { 56 56 }
									}
								}
								textbox = {
									size = { 300 28 }
									using = BaseFontM
									using = Default_FontColor
									text = "GREAT_GAME_RUSSIA_TITLE"
								}
							}
							# Tension bar
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_TENSION_LABEL"
									tooltip = "GREAT_GAME_TENSION_TT"
								}
								# [#264 develop] Tension number moved LEFT of the bar (user request) so it lines
								# up under the Standing value column instead of floating past the bar's right end.
								textbox = {
									size = { 40 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "[Player.MakeScope.GetVariable('qing_gp_tension_russia').GetValue|0]"
								}
								progressbar = {
									using = progressbar_flat_green
									size = { 240 12 }
									value = "[FixedPointToFloat( Multiply_CFixedPoint( Player.MakeScope.GetVariable('qing_gp_tension_russia').GetValue, '(CFixedPoint)0.01' ) )]"
								}
							}
							# Standing (opinion)
							flowcontainer = {
								spacing = 8
								textbox = {
									size = { 80 20 }
									using = BaseFontS
									using = Default_FontColor
									text = "GREAT_GAME_STANDING_LABEL"
									tooltip = "GREAT_GAME_STANDING_TT"
								}
								textbox = {
									size = { 240 20 }
									using = BaseFontS
