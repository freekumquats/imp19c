			################################################################
			########Subjects view#########################################
			################################################################
			flowcontainer = {
				margin = { 10 }
				visible = "[GetVariableSystem.HasValue( 'diplomatic_tabs', 'subjects' )]"
				state = { 
					name = _hide
					on_start = "[GetVariableSystem.Set( 'diplomatic_windows', 'clear' )]"
				}
				sub_header_v = {
					size = { 220 620 }
					blockoverride "Title_text" { text = "list_subjects" }
					blockoverride "Max_text_width" { max_width = 230 }
					scrollarea = {
						visible = "[Not(IsDataModelEmpty(Player.MakeScope.GetList('player_subjects')))]"
						#using = VerticalScrollAreaCutOff
						size = { 215 600 }
						position = { 0 34 }
						scrollbarpolicy_horizontal = always_off
						scrollbar_vertical = {
							using = VerticalScrollBar
						}
						scrollwidget = {
							flowcontainer = {
								datamodel = "[Player.MakeScope.GetList('player_subjects')]"
								direction = vertical
								item = {
									# [#228] Row = SELECT (show this subject on the right pane); the flag
									# inside still opens the diplomatic view (unchanged, see its On_click).
									# list_button is an overlay behind flag+text: a click on empty row area
									# selects; a click on the flag hits the flag On_click first.
									widget = {
										datacontext = "[Scope.GetCountry]"
										size = { 200 58 }
										list_button = {
											parentanchor = vcenter
											size = { 100% 100% }
											onclick = "[GetScriptedGui('qing_subjects_tab_select_button').Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											down = "[And( Player.MakeScope.GetVariable('SUBJ_tab_selected').IsSet, EqualTo_int32( Country.GetId, Player.MakeScope.GetVariable('SUBJ_tab_selected').GetCountry.GetId ) )]"
											tooltip = "QING_SUBJECT_TAB_SELECT_TT"
										}
										flowcontainer = {
											spacing = 5
										new_country_flag = {
											tooltip = "COUNTRY_SHORTHAND_INFO"
											parentanchor = vcenter
											blockoverride "Flag" {
												texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
												frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
												framesize = { 56 56 }
											}
											blockoverride "FlagOverlord" {
												texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
												frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
												framesize = { 56 56 }
											}
											blockoverride "Size"
											{
												size = { 48 48 }
											}
											blockoverride "On_click"
											{
												# [#168 fix] The Subjects-tab list is NAVIGATION: clicking a
												# subject opens ITS diplomatic view (target = that subject),
												# where the per-subject interaction buttons live (see the
												# subject-interactions panel added to the Diplomatic tab). The
												# subjects-tab right pane cannot host the action buttons — it is
												# only shown while viewing the PLAYER's own country, so a button
												# gated on scope:target = { is_subject_of = ROOT } can never pass
												# there. Was commented out upstream, leaving the list inert.
												onclick = "[OpenDiplomacy(Country.GetCountry)]"
											}
										}
										tag_dark = {
											# [develop #247] Row label is the SUBJECT'S NAME, not FOREIGN_INFLUENCE_TT.
											# That key resolves to a full sentence ("X has influence in Y of Z%") which
											# overflowed the 135px cell and collided with the flag/neighbours (the
											# "text overlaps text" bug). Show the country name; keep the shorthand tooltip.
											text = "[Country.GetName]"
											tooltip = "[Country.GetDescriptiveName]"
											max_width = 135
											elide = right
										}
										}
									}
								}
							}
						}
					}
				}
				flowcontainer = {
						# [#228] Whole right pane describes the SELECTED subject (row-click), not
						# the overlord. datacontext resolves the stored selection; children read Country.
						# Gated on .IsSet so the Country.* reads never evaluate against an unset
						# variable (zero-subject Qing, or the clear→reseed transient on tab toggle).
						datacontext = "[Player.MakeScope.GetVariable('SUBJ_tab_selected').GetCountry]"
						visible = "[Player.MakeScope.GetVariable('SUBJ_tab_selected').IsSet]"
					direction = vertical
					spacing = 16
					widget = {
						size = { 460 28 }
						visible = "[Not(IsDataModelEmpty(Player.MakeScope.GetList('player_subjects')))]"
						#parentanchor = bottom
						#ignoreinvisible = yes
						text_button_square_highlighted = {
							size = { 240 28 }
							parentanchor = center
							visible = "[Not(GetVariableSystem.HasValue( 'diplomatic_windows', 'show_national_interactions' ))]"
							blockoverride "Center_text"
							{
								text = "show_national_interactions"
							}
							blockoverride "On_click"
							{
								onclick = "[GetVariableSystem.Set( 'diplomatic_windows', 'show_national_interactions' )]"
							}
							tooltip = "show_national_interactions"
						}
						text_button_square_highlighted = {
							size = { 240 28 }
							parentanchor = center
							visible = "[GetVariableSystem.HasValue( 'diplomatic_windows', 'show_national_interactions' )]"
							blockoverride "Center_text"
							{
								text = "show_national_interactions"
							}
							blockoverride "On_click"
							{
								onclick = "[GetVariableSystem.Set( 'diplomatic_windows', 'clear' )]"
							}
							tooltip = "show_national_interactions"
						}
					}
					flowcontainer = {
						spacing = 10
						flowcontainer = {
							direction = vertical
							widget = { #flag
								parentanchor = center
								size = { 180 70 }
								cpt_button = {
									parentanchor = left
									size = { 50 77 }
									position = { 20 -5 }
									block "Context" 
									{
										datacontext = "[Country.GetRuler]"
										visible = "[Not(Country.IsBarbarian)]"
									}
								}
								new_country_flag = {
									datacontext = "[Country]"
									tooltip = "[Country.GetRankInformation]"
									parentanchor = right
									position = { -10 0 }
									blockoverride "Flag" {
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
										framesize = { 120 120 }
									}
									blockoverride "FlagOverlord" {
										texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)120','(int32)120')]"
										frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)120','(int32)120')]"
										framesize = { 120 120 }
									}
									blockoverride "Size"
									{
										size = { 70 70 }
									}
									blockoverride "On_click"
									{
										#onclick = "[OpenDiplomacy(Country.GetCountry)]" #change this
									}
								}
							}
							icon_and_text = { #country name
								size = { 140 20 }
								parentanchor = center
								tooltip = "[Country.GetName]"
								blockoverride "LineSize"
								{
									size = { 100 4 }
								} 
								blockoverride "Icon"
								{
									visible = no
								}
								blockoverride "Text"
								{
									position = { 0 0 }
									text = "[Country.GetNameWithNoTooltip]"
									align = center|center
									multiline = no
									fontsize = 20
								}
							}
						}
						flowcontainer = {
							direction = vertical
							ignoreinvisible = yes
							spacing = 10
							icon_and_text = { #religion
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/powers/religious.dds" }
								blockoverride "Text" { text = "[Country.GetReligion.GetName]" }
								tooltip = "[Country.GetReligion.GetTooltip]"
							}
							icon_and_text = { #culture
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/governor_policies/cultural_assimilation.dds" }
								blockoverride "Text" { text = "[Country.GetPrimaryCulture.GetName]" }
								tooltip = "[Country.GetPrimaryCulture.GetTooltip]"
							}
							icon_and_text = { #manpower
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/manpower.dds" }
								blockoverride "Text" { text = "[Country.GetManpower]" }
								tooltip = "[Country.GetManpowerTooltip]"
							}
						}
						flowcontainer = {
							direction = vertical
							ignoreinvisible = yes
							spacing = 10
							icon_and_text = { #treasury
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/treasury.dds" }
								blockoverride "Text" { text = "[Country.GetTreasury|0]" }
								tooltip = "[Country.GetTreasuryTooltip]"
							}
							icon_and_text = { #pop
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/pop_type.dds" }
									# [#171] was hardcoded "Egg" placeholder
									blockoverride "Text" { text = "[Country.GetTotalPopulation]" }
								tooltip = "[Country.BuildTotalPopulationToolTip]"
							}
							icon_and_text = { #stability
								size = { 120 32 }
								blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/stability.dds" }
								blockoverride "Text" { text = "[Country.GetStability|2]" }
								tooltip = "[Country.GetStabilityTooltip]"
							}
						} 
					}
					flowcontainer = {
						# [#314 B16 fix] The Overseer portrait showed the SUBJECT RULER, never the overseer. The real
						# overseer is the resident Amban (理藩院), stored on the subject as the qing_amban_here character
						# var. Show that man when posted; when vacant the portrait hides and the Post-Amban button shows.
						icon = {
							parentanchor = center
							size = { 65 70 }
							visible = "[Country.MakeScope.Var('qing_amban_here').IsSet]"
							cpt_button = {
								parentanchor = left
								size = { 50 77 }
								position = { 10 -5 }
								block "Context" 
								{
									datacontext = "[Country.MakeScope.Var('qing_amban_here').GetCharacter]"
									visible = "[Country.MakeScope.Var('qing_amban_here').IsSet]"
								}
							}
						}
						# [#314 B16 fix] Post-Amban action lifted up beside the portrait (was only in the buried
						# Subject-Actions strip). Shown only when the post is vacant.
						icon_button_square = {
							parentanchor = vcenter
							size = { 40 40 }
							datacontext = "[GetScriptedGui('qing_amban_manage_post_button')]"
							visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
							blockoverride "On_click"
							{
								enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
								onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
								clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
								oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
								inherit_visual_state = no
							}
							blockoverride "Icon"
							{
								texture = "gfx/interface/icons/shared_icons/oratory.dds"
								size = { 34 34 }
							}
							tooltip = "QING_AMBAN_MANAGE_POST_TT"
						}
						flowcontainer = {
							direction = vertical
							layoutpolicy_horizontal = expanding
							flowcontainer = {
								icon_and_text = {
									size = { 200 20 }
									tooltip = "Overseer"
									blockoverride "LineSize"
									{
										size = { 200 4 }
									} 
									blockoverride "Icon"
									{
										visible = no
									}
									blockoverride "Text"
									{
										position = { 0 0 }
										text = "Overseer"
										align = left
										multiline = no
										fontsize = 20
									}
								}
								widget = {
									name = "modifier_reward"
									size = { 150 32 }
									using = NoninteractableBG
									blockoverride "Margins" {}
									visible = "[OfficeHolderItem.HasHolder]"
									modifier_desc_condensed = {
										position = { 0 -4 } 
										parentanchor = center
										widgetanchor = center
										datacontext = "[OfficeHolderItem.GetModifier]"
										tooltip = "[OfficeHolderItem.GetTooltip]"
										scale = 0.9
									}
								}
							}
							flowcontainer = { 
								margin_top = 10
									# [BT-18] Recall moved UP to the LEFT of the (higher) Replace icon by the portrait; the redundant
									# lower Replace in the buried Subjects-tab strip was removed. Recall + Replace now sit together.
									# ---- AMBAN (#163) manual management: recall / replace / return-to-auto ----
									# RECALL AMBAN - withdraw the resident, leaving the post vacant
									icon_button_square = {
										size = { 40 40 }
										datacontext = "[GetScriptedGui('qing_amban_manage_recall_button')]"
										visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
										blockoverride "On_click"
										{
											enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
											oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
											inherit_visual_state = no
										}
										blockoverride "Icon"
										{
											texture = "gfx/interface/icons/shared_icons/tactical.dds"
											size = { 34 34 }
										}
										tooltip = "QING_AMBAN_MANAGE_RECALL_TT"
									}
									# [#171] repurposed the dead "Change Overseer" placeholder into the
									# amban-swap action (replace the resident amban). Wired to the same
									# qing_amban_manage_replace scripted GUI used by the #168 button strip.
									icon_button_square = {
										size = { 40 40 }
										datacontext = "[GetScriptedGui('qing_amban_manage_replace_button')]"
										visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
										blockoverride "On_click"
										{
											enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
											oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
											inherit_visual_state = no
										}
										blockoverride "Icon"
										{
											texture = "gfx/interface/icons/shared_icons/change.dds"
											size = { 34 34 }
										}
										tooltip = "QING_AMBAN_MANAGE_REPLACE_TT"
									}
									# [BT-18 follow-up] Return-to-Auto moved UP next to Recall+Replace by the portrait too; the whole
									# buried Subjects-tab icon strip (which overlapped the status text) is now empty and gone.
									# RETURN TO AUTOMATIC - hand the post back to the quarterly Lifan Yuan pulse
									icon_button_square = {
										size = { 40 40 }
										datacontext = "[GetScriptedGui('qing_amban_manage_return_auto_button')]"
										visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
										blockoverride "On_click"
										{
											enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', Country.MakeScope ).End )]"
											clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
											oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
											inherit_visual_state = no
										}
										blockoverride "Icon"
										{
											texture = "gfx/interface/icons/shared_icons/time.dds"
											size = { 34 34 }
										}
										tooltip = "QING_AMBAN_MANAGE_RETURN_AUTO_TT"
									}
								widget = {
									size = { 150 40 }
									icon = {
										size = { 150 40 }
