														parentanchor = left|vcenter 
														align = left
														position = { 16 -2 }
														max_width = 300
													}
													blockoverride "Text" { text = "Trade Actions" }
													blockoverride "On_click" { onclick = "[GetVariableSystem.Set( 'trade_actions_open', 'yes' )]" }
													blockoverride "Down" { visible = no }
													blockoverride "Right" { visible = yes }
													blockoverride "RightArrowVisible" { visible = yes }
												
													visible = "[Not( GetVariableSystem.HasValue( 'trade_actions_open', 'yes' ) )]"
												}
											}

										}

										vbox = {
											visible = "[And(GetVariableSystem.HasValue( 'trade_actions_open', 'yes' ), And(Not(DiplomaticView.GetTargetCountry.IsBarbarian), Not(EqualTo_int32( DiplomaticView.GetTargetCountry.GetId, Player.GetId ))))]"
											margin_left = -2
											margin_right = 32
											margin_top = 10
											layoutpolicy_horizontal = expanding
											# Trade agreement - all
											diplomacy_action_button = {
												size = { 0 22 }
												layoutpolicy_horizontal = expanding
												margin = { 14 0 }
												margin_right = 0

												datacontext = "[GetScriptedGui('trade_agreement_all_button')]"
												parentanchor = hcenter

												enabled = "[ScriptedGui.IsValid(GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End)]"

												blockoverride "On_click"
												{
													enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('recipient', Country.MakeScope).End )]"
													onclick = "[ScriptedGui.Execute(GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End)]"
												}

												blockoverride "Left_text" 
												{ 
													margin_left = 24
													text = "[Select_CString( ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope).End ), 'Cancel Trade Agreement', 'Trade Agreement' )]"
												}
												
												blockoverride "Right_text"
												{
													text = ""
													using = Negative_FontColor
													# Make fontcolor conditional
													tooltip = "[ScriptedGui.BuildTooltip(GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End)]"
												}	
												
												blockoverride "Icon" 
												{
													framesize = { 46 46 }
													#visible = "[DiplomaticActionItem.RequireAcceptance]"
													texture = "gfx/interface/base_parts/accept_decline_flat.dds"
													frame = "[Select_int32(ScriptedGui.IsValid(GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End),'(int32)2','(int32)1')]"
													tooltip = "[ScriptedGui.BuildTooltip(GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End)]"
												}	

												tooltip =  "[SelectLocalization( ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope).End ), 'cancel_trade_agreement_all_tt_title', 'offer_trade_agreement_all_tt_title' )]#T [DiplomaticView.GetTargetCountry.GetName] #! [SelectLocalization( ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope).End ), 'cancel_trade_agreement_all_tt_body', 'offer_trade_agreement_all_tt_body' )]"
											}

											#widget = { size = { 0 4 } } # Adds spacing between diplo buttons

											#widget = { size = { 0 4 } } # Adds spacing between diplo buttons
										}


										################################################################
										# [#176 fix] SUBJECT ACTIONS dropdown. The former inline block (a t4
										# sibling of the whole actions area) did not render for the player; per
										# user direction the per-subject verbs now live in a collapsible
										# "Subject Actions" category placed directly BELOW Trade Actions, mirroring
										# that dropdown. Gated CHI + target is one of the player's own subjects.
										################################################################
										# [#227 fix] Spacer between Trade Actions (above) and Subject Actions
										# (below) so the two headers are not directly adjacent. Matches the
										# inter-section rhythm the other bars get; gated identically to the
										# Subject bar so it only occupies space when the bar is shown.
										widget = {
											size = { 0 10 }
											visible = "[And( EqualTo_string( Player.GetTag, 'CHI' ), And( DiplomaticView.GetTargetCountry.IsSubject, EqualTo_int32( DiplomaticView.GetTargetCountry.GetOverlord.GetId, Player.GetId ) ) )]"
										}
										margin_widget = {
											size = { 0 28 }
											layoutpolicy_horizontal = expanding
											margin = { 7 0 }
											margin_right = 0
											visible = "[And( EqualTo_string( Player.GetTag, 'CHI' ), And( DiplomaticView.GetTargetCountry.IsSubject, EqualTo_int32( DiplomaticView.GetTargetCountry.GetOverlord.GetId, Player.GetId ) ) )]"
											vbox = {
												layoutpolicy_horizontal = expanding
												margin_right = 22 # [#227 fix] match Trade Actions bar right edge (was absent → bar ran too long)
												category_drop = {
													name = "close_button_subject_dip"
													layoutpolicy_horizontal = expanding
													size = { 0 32 }
													blockoverride "Text_alignment" { parentanchor = left|vcenter  align = left  position = { 16 -2 }  max_width = 300 }
													blockoverride "Text" { text = "QING_SUBJECT_ACTIONS_HEADER" }
													blockoverride "On_click" { onclick = "[GetVariableSystem.Set( 'subject_actions_open', 'no' )]" }
													blockoverride "Down" { visible = yes }
													blockoverride "Right" { visible = no }
													blockoverride "RightArrowVisible" { visible = no }
													visible = "[GetVariableSystem.HasValue( 'subject_actions_open', 'yes' )]"
												}
												category_drop = {
													name = "open_button_subject_dip"
													layoutpolicy_horizontal = expanding
													size = { 0 32 }
													blockoverride "Text_alignment" { parentanchor = left|vcenter  align = left  position = { 16 -2 }  max_width = 300 }
													blockoverride "Text" { text = "QING_SUBJECT_ACTIONS_HEADER" }
													blockoverride "On_click" { onclick = "[GetVariableSystem.Set( 'subject_actions_open', 'yes' )]" }
													blockoverride "Down" { visible = no }
													blockoverride "Right" { visible = yes }
													blockoverride "RightArrowVisible" { visible = yes }
													visible = "[Not( GetVariableSystem.HasValue( 'subject_actions_open', 'yes' ) )]"
												}
											}
										}
										vbox = {
											visible = "[And( GetVariableSystem.HasValue( 'subject_actions_open', 'yes' ), And( EqualTo_string( Player.GetTag, 'CHI' ), And( DiplomaticView.GetTargetCountry.IsSubject, EqualTo_int32( DiplomaticView.GetTargetCountry.GetOverlord.GetId, Player.GetId ) ) ) )]"
											layoutpolicy_horizontal = expanding
											margin_left = -2
											margin_right = 32
											margin_top = 10
											# [#314 B15 fix] autoresize=yes gave this header 0 layout height inside the vbox,
											# so the Integrate/Loosen action buttons below stacked ON TOP of the header + subject-
											# type text. Fixed size + multiline lets the vbox reserve real height so buttons flow below.
											textbox = {
												size = { 300 28 }
												multiline = yes
												using = BaseFontM
												using = Default_FontColor
												text = "QING_SUBJECT_INTERACTIONS_HEADER"
											}
											# [#314 B15-v2 fix] was an `only_text` widget, which (like the old autoresize header)
											# does NOT reserve layout height inside the vbox — so the Integrate/Loosen buttons below
											# STILL stacked on top of it after the header was fixed. Converted to a fixed-size multiline
											# `textbox` (identical to the header above) so the vbox reserves real height for this row too
											# and every button flows cleanly below it. Same SelectLocalization subject-type text + tooltip.
											textbox = {
												size = { 300 28 }
												multiline = yes
												using = BaseFontM
												using = Default_FontColor
												text = "[SelectLocalization( GetScriptedGui('qing_subject_type_is_tributary').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_TRIBUTARY', SelectLocalization( GetScriptedGui('qing_subject_type_is_nominal_vassal').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_NOMINAL_VASSAL', SelectLocalization( GetScriptedGui('qing_subject_type_is_feudatory').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_FEUDATORY', SelectLocalization( GetScriptedGui('qing_subject_type_is_protectorate').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_PROTECTORATE', 'QING_SUBJECT_TYPE_AUTONOMOUS_GOVERNORSHIP' ) ) ) )]"
												tooltip = "[SelectLocalization( GetScriptedGui('qing_subject_type_is_tributary').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_TRIBUTARY', SelectLocalization( GetScriptedGui('qing_subject_type_is_nominal_vassal').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_NOMINAL_VASSAL', SelectLocalization( GetScriptedGui('qing_subject_type_is_feudatory').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_FEUDATORY', SelectLocalization( GetScriptedGui('qing_subject_type_is_protectorate').IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End ), 'QING_SUBJECT_TYPE_PROTECTORATE', 'QING_SUBJECT_TYPE_AUTONOMOUS_GOVERNORSHIP' ) ) ) )]"
											}
											widget = {
												size = { 300 40 }
												visible = "[DiplomaticView.GetTargetCountry.MakeScope.Var('SUBJ_integration_progress').IsSet]"
												textbox = {
													using = BaseFontM
													using = Default_FontColor
													block "progress_text" { text = "[DiplomaticView.GetTargetCountry.MakeScope.GetVariable('SUBJ_integration_progress').GetValue|0] / 5" }
												}
												widget = {
													position = { 0 22 }
													size = { 290 8 }
													progressbar = {
														using = progressbar_flat_green
														size = { 290 8 }
														block "progress_value"
														{
															value = "[FixedPointToFloat( Multiply_CFixedPoint( DiplomaticView.GetTargetCountry.MakeScope.GetVariable('SUBJ_integration_progress').GetValue, '(CFixedPoint)0.2' ) )]"
														}
													}
												}
											}
											# [#217 fix] Subject/amban action as a red text button (name left, cost
											# right), matching Relation/Trade Actions; was an icon_button_square.
											diplomacy_action_button = {
												size = { 0 22 }
												layoutpolicy_horizontal = expanding
												margin = { 14 0 }
												margin_right = 0
												parentanchor = hcenter
												datacontext = "[GetScriptedGui('qing_subject_promote_button')]"
												visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
												enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
												blockoverride "On_click"
												{
													enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
													onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
													clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
													oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
												}
												blockoverride "Left_text"
												{
													margin_left = 24
													text = "QING_SUBJECT_PROMOTE_NAME"
												}
												blockoverride "Right_text"
												{
													text = "QING_SUBJECT_PROMOTE_COST"
												}
												blockoverride "Icon" { visible = no }  # [#217 fix] suppress template placeholder icon
												tooltip = "QING_SUBJECT_PROMOTE_TT"
											}
											# [#217 fix] Subject/amban action as a red text button (name left, cost
											# right), matching Relation/Trade Actions; was an icon_button_square.
											diplomacy_action_button = {
												size = { 0 22 }
												layoutpolicy_horizontal = expanding
												margin = { 14 0 }
												margin_right = 0
												parentanchor = hcenter
												datacontext = "[GetScriptedGui('qing_subject_incorporate_button')]"
												visible = "[ScriptedGui.IsShown( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
												enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
												blockoverride "On_click"
												{
													enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
													onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( Player.MakeScope ).AddScope('target', DiplomaticView.GetTargetCountry.MakeScope ).End )]"
													clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_sub_tab"
													oversound = "event:/SFX/UI/Generic/sfx_ui_generic_mouse_over"
												}
												blockoverride "Left_text"
