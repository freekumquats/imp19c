										modify_texture = {
											name = "Alpha"
											texture = "gfx/interface/base_parts/header_l_x20bd_alpha1.dds"
											blend_mode = alphamultiply
											spriteType = Corneredtiled
											spriteborder = { 52 0 }
										}
									}
									flowcontainer = {
										layoutpolicy_horizontal = expanding
										margin_top = 7
										spacing = 6
										widget = { size = { 10 0 } }
										# [#314 B17] tribute tier button (was a dead policy_button toggle)
