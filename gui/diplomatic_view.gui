													blockoverride "RightArrowVisible" { visible = no }

													visible = "[GetVariableSystem.HasValue( 'trade_actions_open', 'yes' )]"
												}

												category_drop = {
													name = "open_button_trade_dip"
													layoutpolicy_horizontal = expanding
													size = { 0 32 }
													blockoverride "Text_alignment" 
