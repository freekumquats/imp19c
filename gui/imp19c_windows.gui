# [#29] TAKE-A-CONSORT PICKER — a movable roster of court women eligible to enter the inner
# court (後宮), for the Imperial Harem panel (qing_harem.gui). The TAKE A CONSORT lever there
# refreshes qing_harem_candidates (via the qing_harem.3 trampoline) then opens THIS window;
# clicking a woman's row takes her as a consort (qing_harem_take_consort) and closes the
# window. Replaces the old inline list of per-row "Take Consort" buttons. Mirrors the Grand
# Council Appoint picker + the #6 justice accuse picker above.
base_window = {
	name = "qing_harem_take_window"
	gfxtype = windowgfx
	parentanchor = center
	movable = yes
	size = { 620 700 }
	vbox = {
		using = MainWindowHeaderBoxCentered
		blockoverride "Title_text" { text = "QING_HAREM_TAKE_PICKER_HEADER" }
		scrollarea = {
			size = { 600 640 }
			scrollbarpolicy_horizontal = always_off
			scrollbar_vertical = { using = VerticalScrollBar }
			scrollwidget = {
				flowcontainer = {
					direction = vertical
					spacing = 6
					margin = { 8 6 }
					textbox = {
						using = BaseFontS
						using = Default_FontColor
						size = { 570 44 }
						multiline = yes
						alpha = 0.75
						fontsize_min = 11
						text = "QING_HAREM_TAKE_PICKER_INSTR"
					}
					textbox = {
						visible = "[IsDataModelEmpty( Player.MakeScope.GetList('qing_harem_candidates') )]"
						using = BaseFontS
						using = Default_FontColor
						size = { 570 26 }
						alpha = 0.6
						text = "QING_HAREM_TAKE_EMPTY"
					}
					dynamicgridbox = {
						datamodel = "[Player.MakeScope.GetList('qing_harem_candidates')]"
						item = {
							button = {
								size = { 568 84 }
								margin = { 2 3 }
								datacontext = "[Scope.GetCharacter]"
								using = background_widget
								blockoverride "Margin" { margin = { 2 2 } }
								# row-click take-as-consort. Own scope (Character + player) so the button keeps
								# the CHARACTER datacontext for the child reads below (mirror the office picker).
								enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[GetScriptedGui('qing_harem_take_consort').Execute( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_harem_take_window')]"
								tooltip = "QING_HAREM_TAKE_ROW_TT"
							flowcontainer = {
									spacing = 8
									margin = { 8 6 }
									cpt_button = { size = { 46 68 } }
									flowcontainer = {
										direction = vertical
										spacing = 3
										tag = { text = "[Character.GetName]"  maximumsize = { 300 24 }  using = BaseFontM  using = Default_FontColor }
										flowcontainer = {
											spacing = 10
											icon_and_text = {
												size = { 66 24 }
												blockoverride "Icon" { using = icon_oratory }
												blockoverride "Text" { text = "[Character.GetCharisma]" }
												tooltip = "[Character.GetCharismaToolTip]"
											}
											icon_and_text = {
												size = { 66 24 }
												blockoverride "Icon" { using = icon_civic }
												blockoverride "Text" { text = "[Character.GetFinesse]" }
												tooltip = "[Character.GetFinesseToolTip]"
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
	button_close = {
		onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_harem_take_window')]"
		tooltip = "CLOSE"
		parentanchor = top|right
		position = { -7 10 }
	}
}

########################################################################
# [#9 boot] qing_harem_favour_window — FAVOUR A CONSORT (臨幸) picker. Cloned byte-for-byte from
# qing_harem_take_window above (the proven picker), only the window name, header/instr/empty loc,
