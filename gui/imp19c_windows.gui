########################################################################
# [#9 boot] qing_harem_promote_window — PROMOTE A CONSORT (晉封) picker. Clone of the favour window;
# datamodel = qing_harem_promotable, row scripted_gui = qing_harem_promote_selected. Only consorts
# eligible to rise (below the top rank, next tier under its cap) appear (list built in
# QING_harem_refresh_promotable). A row-click elevates the chosen woman one rank and closes.
########################################################################
base_window = {
	name = "qing_harem_promote_window"
	gfxtype = windowgfx
	parentanchor = center
	movable = yes
	size = { 620 700 }
	vbox = {
		using = MainWindowHeaderBoxCentered
		blockoverride "Title_text" { text = "QING_HAREM_PROMOTE_PICKER_HEADER" }
		scrollarea = {
			size = { 600 640 }
			scrollbarpolicy_horizontal = always_off
			scrollbar_vertical = { using = VerticalScrollBar }
			scrollwidget = {
				flowcontainer = {
					direction = vertical
					spacing = 6
					margin = { 8 6 }
					textbox = {
						using = BaseFontS
						using = Default_FontColor
						size = { 570 44 }
						multiline = yes
						alpha = 0.75
						fontsize_min = 11
						text = "QING_HAREM_PROMOTE_PICKER_INSTR"
					}
					textbox = {
						visible = "[IsDataModelEmpty( Player.MakeScope.GetList('qing_harem_promotable') )]"
						using = BaseFontS
						using = Default_FontColor
						size = { 570 26 }
						alpha = 0.6
						text = "QING_HAREM_PROMOTE_EMPTY"
					}
					dynamicgridbox = {
						datamodel = "[Player.MakeScope.GetList('qing_harem_promotable')]"
						item = {
							button = {
								size = { 568 84 }
								margin = { 2 3 }
								datacontext = "[Scope.GetCharacter]"
								using = background_widget
								blockoverride "Margin" { margin = { 2 2 } }
								enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[GetScriptedGui('qing_harem_promote_selected').Execute( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_harem_promote_window')]"
								tooltip = "QING_HAREM_PROMOTE_ROW_TT"
							flowcontainer = {
									spacing = 8
									margin = { 8 6 }
									cpt_button = { size = { 46 68 } }
									flowcontainer = {
										direction = vertical
										spacing = 3
										tag = { text = "[Character.GetName]"  maximumsize = { 300 24 }  using = BaseFontM  using = Default_FontColor }
										textbox = {
											size = { 300 20 }
											using = BaseFontS
											using = Default_FontColor
											text = "[Character.Custom('qing_consort_rank_name')]"
										}
										flowcontainer = {
											spacing = 10
											icon_and_text = {
												size = { 66 24 }
												blockoverride "Icon" { using = icon_oratory }
												blockoverride "Text" { text = "[Character.GetCharisma]" }
												tooltip = "[Character.GetCharismaToolTip]"
											}
											icon_and_text = {
												size = { 66 24 }
												blockoverride "Icon" { using = icon_civic }
												blockoverride "Text" { text = "[Character.GetFinesse]" }
												tooltip = "[Character.GetFinesseToolTip]"
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
	button_close = {
		onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_harem_promote_window')]"
		tooltip = "CLOSE"
		parentanchor = top|right
		position = { -7 10 }
	}
}


types SupranationalWindows
{	
	type candidate = widget {
		size = { 250 60 }
	    new_country_flag = {
	        tooltip = "[Scope.GetCountry.GetName]"
	        datacontext = "[Province.MakeScope.GetVariable('host_tag').GetCountry]"
	        parentanchor = vcenter
			blockoverride "Flag" {
				texture = "[Country.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
				frame = "[Country.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
				framesize = { 56 56 }
			}
			blockoverride "FlagOverlord" {
				texture = "[Country.GetOverlord.AccessCoatOfArms.GetTexture('(int32)56','(int32)56')]"
				frame = "[Country.GetOverlord.AccessCoatOfArms.GetFrame('(int32)56','(int32)56')]"
				framesize = { 56 56 }
			}
	        blockoverride "Size"
	        {
	            size = { 42 42 }
	        }
	    }
		only_text = {
			size = { 120 32 }
			position = { 46 0 }
			#block "TextBox" { text = "Candidate" }
		}
	    textbox = {
			size = { 120 20 }
			multiline = no
			position = { 50 28 }
			block "Candidate_name" { text = "Name" }
			fontsize = 16
			elide = right
			align = bottom
			using = BaseFontS
			using = Highlight_FontColor
			block "Candidate_name_tt" { tooltip = "Candidate name" }
		}
	    textbox = {
			size = { 40 50 }
			multiline = no
			position = { 200 0 }
			block "Num_votes" { text = "0" }
			fontsize = 20
			elide = right
			align = center
			using = BaseFontS
			using = Positive_FontColor
			tooltip = "num votes"
		}
	}

@mincategorybuttonwidth = 181
@maxcategorybuttonwidth = 181
@mincategorybuttonheight = 42
@maxcategorybuttonheight = 42
@window_width = 948
@window_height = 700

	# [develop #263-fix] Diplomatic-play window opened NOTHING under HEAD 6a9ba7c2. The
	# ONLY diff from upstream's (working) block was the earlier #249 datacontext edit,
	# which removed this root datacontext and relocated it into the federation tab. That
	# relocation was the regression: this block is otherwise identical to upstream and the
	# braces balance cleanly (verified with a comment/string-aware depth tracker — there is
	# NO stray brace; an earlier grep-based count was wrong). Fix: restore upstream's block
	# verbatim, incl. this root datacontext. Opener path (outliner.gui/ingame_topbar.gui)
	# was already identical to upstream, so it was not implicated.
	type supranational = base_window {
		name = "supranational" #name used in console command to open widget
		gfxtype = windowgfx
		parentanchor = center
		movable = no
		# [#314 B14 fix] The window-root datacontext was Player...member_of_federation.GetProvince.
		# When the player is NOT in a federation (e.g. the Qing at the 1763 start) that variable is
		# unset, the root datacontext resolves to nothing, and the engine culls the whole window — so
		# clicking Supranational opened NOTHING. This block is byte-identical to upstream, which "works"
		# only because that save's player happens to be in a federation. The Province scope is used
		# ONLY by the federation tab, so the datacontext is relocated there (see the federation-tab
		# flowcontainer below); the window + the diplomatic-plays/global-powers tabs no longer depend
		# on federation membership and always open. (This restores the #249 relocation that #263 wrongly
		# reverted "to match upstream".)
		size = { 1300 @window_height }
		state = {
			name = _show
			start_sound = {
				soundeffect = "event:/SFX/UI/Generic/2.0/sfx_ui_window_tab_close"
			}
			on_start = "[GetVariableSystem.Set('supranational_tabs', 'diplomatic_plays')]"
		}
		flowcontainer = {
			#spacing = -2
			flowcontainer = {
				margin_left = 10
				margin_top = 10
				spacing = 5
				sub_header_v = {
					size = { 335  680 }
					blockoverride "Title_text" { text = "global_power" }
					blockoverride "Max_text_width" { max_width = 230 }
					scrollarea = {
						size = { 330 640 }
						position = { 0 38 }
						scrollbar_vertical = {
							using = VerticalScrollBar
							blockoverride "Wheelstep" { wheelstep = 80 }
						}
						scrollbarpolicy_horizontal = always_off
						scrollwidget = {
							flowcontainer = {
								spacing = 5
								direction = vertical
								datamodel = "[GetGlobalList('global_powers_list')]"
								item = {
									global_powers = { }
								}
							}
						}
					}
				}
			}
			widget = {
				size = { 7 693 }
				icon = {
					position = { 7 3 }
					using = brighten_red_background
					size = { 2 100% }
				}
			}
			flowcontainer = {
				direction = vertical
				ignoreinvisible = yes
				widget = {
					size = { @window_width 12 }
					using = MainWindowHeaderLine
				}
				margin_widget = {
					size = { @window_width 58 }
					hbox = { 
						layoutpolicy_vertical = preferred
						layoutpolicy_horizontal = expanding
						spacing = -2
						margin_widget = {
							visible = "[GetVariableSystem.HasValue('supranational_tabs', 'diplomatic_plays')]"
							using = MainWindowHeaderContentLeft
							blockoverride "Title_text" { text = "supranational_tab_diplomatic_plays" }
							blockoverride "FlagOrIcon"
							{
								icon = {
									using = gold_background
									size = { 32 32 }
									modify_texture = {
										texture = "gfx/interface/icons/menu_buttons/supranational.dds"
										blend_mode = alphamultiply
									}
								}
							}
						}
						margin_widget = {
							visible = "[GetVariableSystem.HasValue('supranational_tabs', 'federation')]"
							using = MainWindowHeaderContentLeft
							blockoverride "Title_text" { text = "[Player.MakeScope.GetVariable('member_of_federation').GetProvince.MakeScope.GetVariable('federation_name').GetFlagName]" }
							blockoverride "FlagOrIcon"
							{
								icon = {
									using = gold_background
									size = { 32 32 }
									modify_texture = {
										texture = "gfx/interface/icons/menu_buttons/federation.dds"
										blend_mode = alphamultiply
									}
								}
							}
						}
						flowcontainer = {
							spacing = 2
							ignoreinvisible = yes
							category_tab = {
								blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
								blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
								blockoverride "MinVisible" { visible = "[Not( GetVariableSystem.HasValue('supranational_tabs', 'diplomatic_plays'))]" }
								blockoverride "MaxVisible" { visible = "[GetVariableSystem.HasValue('supranational_tabs', 'diplomatic_plays')]" }
								######## Shared Overrides
								blockoverride "Center_text" { text = "supranational_tab_diplomatic_plays" }
								######## Small Button Overrides
								blockoverride "ClickFunction"
								{
									onclick = "[GetVariableSystem.Set('supranational_tabs', 'diplomatic_plays')]"
								}
							}
							category_tab = {
								visible = "[Player.MakeScope.Var('member_of_federation').IsSet]"
								#blockoverride "Enabled" { enabled = "[Player.MakeScope.Var('member_of_federation').IsSet]" }
								blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
								blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
								blockoverride "MinVisible" { visible = "[Not( GetVariableSystem.HasValue('supranational_tabs', 'federation'))]" }
								blockoverride "MaxVisible" { visible = "[GetVariableSystem.HasValue('supranational_tabs', 'federation')]" }
								######## Shared Overrides
								blockoverride "Center_text" { text = "supranational_tab_federation" }
								######## Small Button Overrides
								blockoverride "ClickFunction"
								{
									onclick = "[GetVariableSystem.Set('supranational_tabs', 'federation')]"
								}
							}
						}
						margin_widget = {
							using = MainWindowHeaderContentRight
							icon = {
								position = { 2 50 }
								using = brighten_red_background
								size = { 2 2 }
							}
							blockoverride "White_buttons" 
							{
								button_close = {
									onclick = "[GetVariableSystem.Set( 'supranational_window', 'close' )]"
									tooltip = "CLOSE"
									shortcut = "close_window"
								}
							}
						}
					}
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('supranational_tabs', 'diplomatic_plays')]"
					spacing = 20
					margin = { 10 0 }
					scrollarea = {
						size = { 930 615 }
						#size = { 465 @[ @window_height - 85 ] }
						scrollbar_vertical = {
							using = VerticalScrollBar
							blockoverride "Wheelstep" { wheelstep = 123 }
						}
						scrollbarpolicy_horizontal = always_off
						scrollwidget = {
							flowcontainer = {
								spacing = 5
								direction = vertical
								datamodel = "[GetGlobalList('global_all_diplomatic_plays')]"
								item = {
									diplomatic_play_global_item = { }
								}
							}
						}
					}
				}
				flowcontainer = {
					visible = "[GetVariableSystem.HasValue('supranational_tabs', 'federation')]"
					# [#314 B14 fix] datacontext relocated here from the window root (see the type
					# comment above): the federation tab's Province.MakeScope reads need it, but it is
					# only meaningful — and only shown — while this federation tab is active, so the
					# window itself no longer depends on federation membership to instantiate.
					datacontext = "[Player.MakeScope.GetVariable('member_of_federation').GetProvince]"
					spacing = 10
					margin = { 10 10 }
					flowcontainer = {
						name = "federation_leader"
						direction = vertical
