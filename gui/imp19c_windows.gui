# OPEN WITH: gui.createwidget gui/imp19c_windows.gui example_window
# Just replace "example window" with the name of your widget

base_window = {
	name = "example_window" #name used in console command to open widget
    gfxtype = windowgfx
    parentanchor = center
    size = { 650 550 }
    vbox = {
        using = MainWindowHeaderBoxCentered

        blockoverride "Title_text" { text = "example_window" }

        vbox = {
            layoutpolicy_vertical = expanding
        }

    }
    button_close = {
        onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets example_window')]"
        tooltip = "CLOSE"
        parentanchor = top|right
        position = { -7 10}
    }
}

# [#220/#221/#222] APPOINT-TO-OFFICE PICKER — a single movable roster shared by all
# eleven great offices. The office cards in the Grand Council tab (government_view.gui)
# each carry a small Appoint/Replace button; clicking it (a) records which office was
# chosen in the qing_gc_picker_office GUI var, (b) refreshes the candidate cache sorted
# best-first for THAT office's governing skill (#221), then (c) opens THIS window. Every
# row is one eligible courtier; the single appoint button shown per row is the one whose
# office matches qing_gc_picker_office, so the player simply clicks a name to appoint him.
# Replaces the old "Eligible Courtiers" window that showed all eleven appoint icons on
# every row. Reads the same qing_council_candidates list, scoped through Player.
base_window = {
	name = "qing_office_picker_window"
	gfxtype = windowgfx
	parentanchor = center
	movable = yes
	size = { 640 720 }
	vbox = {
		using = MainWindowHeaderBoxCentered
		blockoverride "Title_text" { text = "QING_GC_PICKER_HEADER" }
		scrollarea = {
			size = { 620 660 }
			scrollbarpolicy_horizontal = always_off
			scrollbar_vertical = { using = VerticalScrollBar }
			scrollwidget = {
				flowcontainer = {
					direction = vertical
					spacing = 6
					margin = { 8 6 }
					textbox = {
						using = BaseFontS
						using = Default_FontColor
						size = { 590 44 }
						multiline = yes
						alpha = 0.75
						fontsize_min = 11
						text = "QING_GC_PICKER_INSTR"
					}
					textbox = {
						visible = "[IsDataModelEmpty( Player.MakeScope.GetList('qing_council_candidates') )]"
						using = BaseFontS
						using = Default_FontColor
						size = { 590 26 }
						alpha = 0.6
						text = "QING_GC_NO_CANDIDATES"
					}
					dynamicgridbox = {
						# [#352 F2 fix] A plain `vbox` does NOT iterate a datamodel — only grid boxes do
						# (dynamicgridbox/fixedgridbox). The B7 change swapped the working dynamicgridbox for a vbox,
						# so the candidate list stopped rendering (the 'Appoint shows no candidates' boot-test bug).
						# Revert to dynamicgridbox — the PROVEN list idiom of every working report
						# (qing_province_reports.gui:49). With NO datamodel_wrap and a full-width (588px in a 620px
						# scrollarea) item, exactly one fits per row, so it stacks VERTICALLY without the horizontal
						# clipping datamodel_wrap=1 caused. `margin` belongs on an inner widget, not the item root.
						datamodel = "[Player.MakeScope.GetList('qing_council_candidates')]"
						item = {
							button = {
								size = { 588 92 }
								margin = { 2 3 }
								datacontext = "[Scope.GetCharacter]"
								using = background_widget
								blockoverride "Margin" { margin = { 2 2 } }
								# [BT-4] Row-click appointment. The Execute/IsValid build their OWN scope
								# (GuiScope.SetRoot Character + player) so the button keeps the CHARACTER datacontext
								# above — child [Character.Get*] reads in the row body still resolve. Do NOT put a
								# GetScriptedGui datacontext on this button (it would override the character and blank the row).
								enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[GetScriptedGui('qing_gov_office_appoint_selected').Execute( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_office_picker_window')]"
								tooltip = "QING_GC_APPOINT_ROW_TT"
							flowcontainer = {
									spacing = 8
									margin = { 8 6 }
									cpt_button = { size = { 50 74 } }
									flowcontainer = {
										direction = vertical
										spacing = 3
										tag = { text = "[Character.GetName]"  maximumsize = { 240 26 }  using = BaseFontM  using = Default_FontColor }
										# [BT-37] incumbent marker under the name (was a clipped 120px column to the right); names the post held.
										# [BT-appointment-redesign 2026-07-22] the picker now lists sitting post-holders as reshuffle
										# candidates, so the marker must show for ANY held post, not only great offices. Gate on the
										# superset court-position custom_loc via the PROVEN Not(StringIsEmpty(...)) idiom (the same test
										# the character-window title row uses at gui_base.gui:6013): it yields "" for a man holding no post
										# (marker hidden) and the post name for anyone holding one — great office, ministry sub-post, study,
										# amban, eunuch, or consort. Replaces the old qing_office_held-only var test, which left a diplomat/
										# censor/guard/study attendant showing NO incumbent line.
										textbox = {
											size = { 300 22 }
											using = BaseFontS
											using = Default_FontColor
											alpha = 0.7
											text = "qing_picker_on_council_marker"
											visible = "[Not( StringIsEmpty( Character.Custom('QING_court_position_or_empty') ) )]"
											tooltip = "QING_PICKER_COUNCIL_SITTER_TT"
										}
										flowcontainer = {
											spacing = 10
											icon_and_text = {
												size = { 82 26 }
												blockoverride "Icon" { using = icon_military }
												blockoverride "Text" { text = "[Character.GetMartial]" }
												tooltip = "[Character.GetMartialToolTip]"
											}
											icon_and_text = {
												size = { 82 26 }
												blockoverride "Icon" { using = icon_civic }
												blockoverride "Text" { text = "[Character.GetFinesse]" }
												tooltip = "[Character.GetFinesseToolTip]"
											}
											icon_and_text = {
												size = { 82 26 }
												blockoverride "Icon" { using = icon_oratory }
												blockoverride "Text" { text = "[Character.GetCharisma]" }
												tooltip = "[Character.GetCharismaToolTip]"
											}
											icon_and_text = {
												size = { 82 26 }
												blockoverride "Icon" { using = icon_religious }
												blockoverride "Text" { text = "[Character.GetZeal]" }
												tooltip = "[Character.GetZealToolTip]"
											}
											icon_and_text = {
												size = { 90 26 }
												blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/loyalty.dds" }
												blockoverride "Text" { text = "[Character.GetLoyalty|0]" }
												tooltipwidget = { using = character_loyalty_tooltip }
											}

										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
	button_close = {
		onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_office_picker_window')]"
		tooltip = "CLOSE"
		parentanchor = top|right
		position = { -7 10 }
	}
}

# [#6] ACCUSE-AN-OFFICIAL PICKER — a movable roster of chargeable courtiers, most-corrupt
# first, for the Board of Punishments (刑部). The ACCUSE lever in the Justice panel
# (qing_justice.gui) refreshes qing_justice_accusable (QING_justice_refresh_accusable) then
# opens THIS window. Every row is one accusable official; clicking a name charges him onto
# the docket (qing_justice_accuse_selected) and closes the window. Mirrors the Grand Council
# Appoint picker (qing_office_picker_window above), but ranked by corruption and dispatching
# the justice charge rather than an office appointment.
base_window = {
	name = "qing_justice_accuse_window"
	gfxtype = windowgfx
	parentanchor = center
	movable = yes
	size = { 640 720 }
	vbox = {
		using = MainWindowHeaderBoxCentered
		blockoverride "Title_text" { text = "QING_JUSTICE_ACCUSE_PICKER_HEADER" }
		scrollarea = {
			size = { 620 660 }
			scrollbarpolicy_horizontal = always_off
			scrollbar_vertical = { using = VerticalScrollBar }
			scrollwidget = {
				flowcontainer = {
					direction = vertical
					spacing = 6
					margin = { 8 6 }
					textbox = {
						using = BaseFontS
						using = Default_FontColor
						size = { 590 44 }
						multiline = yes
						alpha = 0.75
						fontsize_min = 11
						text = "QING_JUSTICE_ACCUSE_PICKER_INSTR"
					}
					textbox = {
						visible = "[IsDataModelEmpty( Player.MakeScope.GetList('qing_justice_accusable') )]"
						using = BaseFontS
						using = Default_FontColor
						size = { 590 26 }
						alpha = 0.6
						text = "QING_JUSTICE_ACCUSE_PICKER_EMPTY"
					}
					dynamicgridbox = {
						datamodel = "[Player.MakeScope.GetList('qing_justice_accusable')]"
						item = {
							button = {
								size = { 588 92 }
								margin = { 2 3 }
								datacontext = "[Scope.GetCharacter]"
								using = background_widget
								blockoverride "Margin" { margin = { 2 2 } }
								# row-click charge. Own scope (GuiScope.SetRoot Character + player) so the
								# button keeps the CHARACTER datacontext for the child reads below.
								enabled = "[ScriptedGui.IsValid( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[GetScriptedGui('qing_justice_accuse_selected').Execute( GuiScope.SetRoot( Character.MakeScope ).AddScope('player', Player.MakeScope ).End )]"
								onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_justice_accuse_window')]"
								tooltip = "QING_JUSTICE_ACCUSE_ROW_TT"
							flowcontainer = {
									spacing = 8
									margin = { 8 6 }
									cpt_button = { size = { 50 74 } }
									flowcontainer = {
										direction = vertical
										spacing = 3
										tag = { text = "[Character.GetName]"  maximumsize = { 240 26 }  using = BaseFontM  using = Default_FontColor }
										flowcontainer = {
											spacing = 10
											icon_and_text = {
												size = { 100 26 }
												blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/corruption.dds" }
												blockoverride "Text" { text = "[Character.GetCorruption|0]" }
												tooltip = "[Character.GetCorruptionToolTip]"
											}
											icon_and_text = {
												size = { 82 26 }
												blockoverride "Icon" { using = icon_civic }
												blockoverride "Text" { text = "[Character.GetFinesse]" }
												tooltip = "[Character.GetFinesseToolTip]"
											}
											icon_and_text = {
												size = { 90 26 }
												blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/loyalty.dds" }
												blockoverride "Text" { text = "[Character.GetLoyalty|0]" }
												tooltipwidget = { using = character_loyalty_tooltip }
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
	button_close = {
		onclick = "[ExecuteConsoleCommand('GUI.ClearWidgets qing_justice_accuse_window')]"
		tooltip = "CLOSE"
		parentanchor = top|right
		position = { -7 10 }
	}
}


# [#9 2026-07-17] IMPEACH-THE-VENAL PICKER — a movable roster of the empire's most corrupt courtiers,
