													name = "statesmanship"
													blockoverride "Icon" {
														# [#352 F13] icon_skills.dds is MISSING (not in upstream either), so the
														# offices-tab statesmanship icon rendered broken/old. Replace with the SAME
														# shared_icons set the Grand Council uses (military/civic/oratory/religious),
														# selected by the office's required-skill frame (1=martial 2=finesse 3=charisma
														# 4=zeal — the icon_skills frame order, same as the technology_view tabs).
														texture = "gfx/interface/icons/shared_icons/military.dds"
														frame = 0
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/military.dds"   visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)1' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/civic.dds"      visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)2' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/oratory.dds"    visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)3' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/religious.dds"  visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)4' )]" }
													}
													blockoverride "Text" { 
														text = "[OfficeHolderItem.GetCharacter.GetEffectiveModifiedAttribute(OfficeHolderItem.GetOffice.GetRequiredSkill)]/[OfficeHolderItem.GetCharacter.GetModifiedAttribute(OfficeHolderItem.GetOffice.GetRequiredSkill)]"
														using = BaseFontM
														using = Default_FontColor
														position = { -10 -4 }
													}
													blockoverride "Value" { value = "[FixedPointToFloat(OfficeHolderItem.GetCharacter.GetExperience)]" }
													tooltip = "[OfficeHolderItem.GetSkillTooltip]"
												}
											}
											flowcontainer = {
												spacing = 5
												ignoreinvisible = yes
												icon_button_square = {
													size = { 36 36 }
													parentanchor = vcenter
													blockoverride "On_click"
													{
														onclick = "[OfficeHolderItem.ChangeHolder]"
														enabled = "[OfficeHolderItem.CanChange]"
													}
													blockoverride "Icon"
													{
														texture = "gfx/interface/icons/shared_icons/change.dds"
														size = { 30 30 }
													}
													
													tooltip = "[OfficeHolderItem.GetChangeTooltip]"
												}
												widget = {
													name = "modifier_reward"
													size = { 240 42 }
													using = NoninteractableBG
													blockoverride "Margins" {}
													visible = "[OfficeHolderItem.HasHolder]"
													modifier_desc_condensed = {
														position = { 0 -4 } 
														parentanchor = center
														widgetanchor = center
														datacontext = "[OfficeHolderItem.GetModifier]"
														tooltip = "[OfficeHolderItem.GetTooltip]"
														scale = 0.9
													}
												}
												flowcontainer = {
													spacing = 2
													visible = "[Not( OfficeHolderItem.GetCharacter.IsValid )]"
													alpha = 0.60
													textbox = {
														using = BaseFontS
														using = Default_FontColor
														parentanchor = vcenter
														autoresize = yes
														elide = right
														max_width = 330
														fontsize_min = 11
														text = "PER_POINT_DESC"
													}
													# [#352 F13] icon_skills.dds is MISSING — use the Grand Council's shared_icons set,
													# selected by the office's required-skill frame (1=martial 2=finesse 3=charisma 4=zeal).
													widget = {
														size = { 34 34 }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/military.dds"   visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)1' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/civic.dds"      visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)2' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/oratory.dds"    visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)3' )]" }
														icon = { size = { 100% 100% }  texture = "gfx/interface/icons/shared_icons/religious.dds"  visible = "[EqualTo_int32( OfficeHolderItem.GetCharacter.GetAttributes.GetFrame(OfficeHolderItem.GetOffice.GetRequiredSkill), '(int32)4' )]" }
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
