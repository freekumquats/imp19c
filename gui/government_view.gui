@mincategorybuttonwidth = 181
@maxcategorybuttonwidth = 181
@mincategorybuttonheight = 42
@maxcategorybuttonheight = 42
@window_width = 990
@window_height = 900

base_window = {
	name = "government_view"
	size = { @window_width @window_height }
	using = main_window_template
	
	### Audio ###
	state = {
		name = _show
		start_sound = {
			soundeffect = "event:/SFX/UI/Generic/2.0/sfx_ui_window_tab_close"
		}
		# [grand-council-tab] the extra Grand Council tab is driven by the qing_gc_tab
		# GUI var (the engine has no 4th native tab). Clear it on open so the view
		# always lands on the vanilla Government tab, never straight into the Qing tab.
		on_start = "[GetVariableSystem.Clear('qing_gc_tab')]"
	}
	state = {
		name = _hide
		start_sound = {
			soundeffect = "event:/SFX/UI/Generic/2.0/sfx_ui_window_tab_close"
		}
	}

	flowcontainer = {
		direction = vertical
		ignoreinvisible = yes
		widget = {
			size = { @window_width 12 }
			using = MainWindowHeaderLine
		}
		margin_widget = {
			size = { @window_width 58 }
			layoutpolicy_horizontal = expanding
			hbox = { 
				layoutpolicy_vertical = preferred
				layoutpolicy_horizontal = expanding
				spacing = -2
				margin_widget = {
					using = MainWindowHeaderContentLeft
					blockoverride "Title_text" { text = "[GovernmentView.GetPlayer.Custom('get_country_formal_adjective')|U] Government" }
					blockoverride "FlagOrIcon"
					{
						icon = {
							using = gold_background
							size = { 32 32 }
							modify_texture = {
								texture = "gfx/interface/icons/menu_buttons/menu_government.dds"
								blend_mode = alphamultiply
							}
						}
					}
				}
				flowcontainer = {
					spacing = 2
					category_tab = {
						name = "government_tab_button"
						tooltip = GOV_VIEW_GOV_TOOLTIP
						blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
						blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
						# [grand-council-tab] show as unselected whenever the Qing tab is active,
						# even though the engine still reports this vanilla tab as shown.
						blockoverride "MinVisible" { visible = "[Or( Not( GovernmentView.IsShowGovernment ), GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') )]" }
						blockoverride "MaxVisible" { visible = "[And( GovernmentView.IsShowGovernment, Not( GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') ) )]" }
						######## Shared Overrides
						blockoverride "Center_text" { text = "GOVERNMENT" }
						######## Small Button Overrides
						blockoverride "ClickFunction"
						{
							onclick = "[GovernmentView.ShowGovernment]"
							onclick = "[GetVariableSystem.Clear('qing_gc_tab')]"
						}
					}   
					category_tab = {
						name = "offices_tab_button"
						tooltip = GOV_VIEW_OFFICES_TOOLTIP
						blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
						blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
						# [grand-council-tab] defer selected-highlight to the Qing tab var.
						blockoverride "MinVisible" { visible = "[Or( Not( GovernmentView.IsShowOffices ), GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') )]" }
						blockoverride "MaxVisible" { visible = "[And( GovernmentView.IsShowOffices, Not( GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') ) )]" }
						######## Shared Overrides
						blockoverride "Center_text" { text = "OFFICES" }
						######## Small Button Overrides
						blockoverride "ClickFunction"
						{
							onclick = "[GovernmentView.ShowOffices]"
							onclick = "[GetVariableSystem.Clear('qing_gc_tab')]"
						}
					}
					category_tab = {
						name = "laws_tab_button"
						tooltip = GOV_VIEW_LAWS_TOOLTIP
						blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
						blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
						# [grand-council-tab] defer selected-highlight to the Qing tab var.
						blockoverride "MinVisible" { visible = "[Or( Not( GovernmentView.IsShowLaws ), GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') )]" }
						blockoverride "MaxVisible" { visible = "[And( GovernmentView.IsShowLaws, Not( GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') ) )]" }
						######## Shared Overrides
						blockoverride "Center_text" { text = "LAWS" }
						######## Small Button Overrides
						blockoverride "ClickFunction"
						{
							onclick = "[GovernmentView.ShowLaws]"
							onclick = "[GetVariableSystem.Clear('qing_gc_tab')]"
						}
					}
					# [grand-council-tab] 4th tab, Qing player only. The three vanilla
					# tabs switch via GovernmentView.IsShow*/Show*; the engine has no 4th
					# native tab, so this one is driven by a GUI variable (qing_gc_tab),
					# the same idiom economy_view.gui uses for its sub-tabs. Selecting it
					# also refreshes the councillor-candidate cache so the pickers are
					# current on open.
					category_tab = {
						name = "grand_council_tab_button"
						visible = "[EqualTo_string( Player.GetTag, 'CHI' )]"
						tooltip = GOV_VIEW_GRAND_COUNCIL_TOOLTIP
						blockoverride "MinSize" { size = { @mincategorybuttonwidth @mincategorybuttonheight } }
						blockoverride "MaxSize" { size = { @maxcategorybuttonwidth @maxcategorybuttonheight } }
						blockoverride "MinVisible" { visible = "[Not( GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') )]" }
						blockoverride "MaxVisible" { visible = "[GetVariableSystem.HasValue('qing_gc_tab', 'grand_council')]" }
						######## Shared Overrides
						blockoverride "Center_text" { text = "GRAND_COUNCIL" }
						######## Small Button Overrides
						blockoverride "ClickFunction"
						{
							onclick = "[GetVariableSystem.Set('qing_gc_tab', 'grand_council')]"
							onclick = "[GetScriptedGui('qing_gov_council_refresh_candidates').Execute( GuiScope.SetRoot( Player.MakeScope ).End )]"
						}
					}
				}
				margin_widget = {
					using = MainWindowHeaderContentRight
					blockoverride "White_buttons" 
					{
						button_back = {
							onclick = "[GovernmentView.OnPrevious]"
							tooltip = "PREVIOUS_GOVERNMENT_VIEW"
							shortcut = "previous_window"
						}
						
						button_close = {
							onclick = "[GovernmentView.OnClose]"
							tooltip = "CLOSE"
							shortcut = "close_window"
						}
					}
				}
			}
		}	
		flowcontainer = {
			name = "Government Tab tab"
			ignoreinvisible = yes
			direction = vertical
			# [grand-council-tab] also hide when the Qing Grand Council tab is active.
				visible = "[And( GovernmentView.IsShowGovernment, Not( GetVariableSystem.HasValue('qing_gc_tab', 'grand_council') ) )]"
			widget = {
				size = { @window_width 290 }
				widget = {
					size = { 800 256 }
					position = { 0 30 }
					parentanchor = hcenter
					datacontext = "[GovernmentView.GetPlayer.GetRuler]"
					background = {
						shaderfile = "gfx/FX/pdxgui_default.shader"
						texture = "[GetCharacterBackgroundIconHuge( Character.Self, Character.GetLocation.GetTerrain )]"
						modify_texture = {
							texture = "gfx/interface/base_parts/gradient_black_flip.dds"
							blend_mode = alphamultiply
						}
						modify_texture = {
							texture = "gfx/interface/base_parts/horizontal_gradient_stretch_black_double.dds"
							blend_mode = alphamultiply
						}
					}
				}
				flowcontainer = {
					direction = vertical
					margin = { 10 0 }
					spacing = 5
					widget = {
						size = { 970 50 }
						using = background_widget
						blockoverride "Margin" { margin = { 2 2 } }
						flowcontainer = {
							margin = { 5 5 }
							spacing = 10
							ignoreinvisible = yes
							widget = {
								size = { 60 40 }
								new_country_flag = {
									datacontext = "[GovernmentView.GetPlayer]"
									tooltip = "[GovernmentView.GetPlayer.GetRankInformation]"
									parentanchor = vcenter
									blockoverride "Size" { size = { 60 60 } }
									blockoverride "Flag"
									{ 
										texture = "[Country.AccessCoatOfArms.GetTexture('(int32)120', '(int32)120')]"
										frame = "[Country.AccessCoatOfArms.GetFrame('(int32)120', '(int32)120'))]"
										framesize = { 120 120 }
									}
									blockoverride "On_click" { onclick = "[ProvinceWindow.OpenDiplomacy]" }
								}
							}
							icon_card = {
								name = "Government Overview Header"
								size = { 290 40 }
								visible = "[GovernmentView.GetPlayer.GetGovernment.IsMonarchy]"
								blockoverride "Icon" { }
								textbox = {
									text = "RULER_TERM_DESCRIPTION_MONARCHY_STANDARD"
									autoresize = yes
									align = center
									parentanchor = center
									position = { 0 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								name = "Government Overview Header Republic"
								size = { 290 40 }
								visible = "[And( GovernmentView.GetPlayer.GetGovernment.IsRepublic, GovernmentView.GetPlayer.GetCoRuler.IsValid )]"
								blockoverride "Icon" { }
								textbox = {
									text = "RULER_TERM_DESCRIPTION_REPUBLIC_CORULER"
									autoresize = yes
									align = center
									parentanchor = center
									position = { 0 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								name = "Government Overview Header Republic No CoRuler"
								size = { 290 40 }
								visible = "[And( GovernmentView.GetPlayer.GetGovernment.IsRepublic, Not( GovernmentView.GetPlayer.GetCoRuler.IsValid ) )]"
								blockoverride "Icon" { }
								textbox = {
									text = "RULER_TERM_DESCRIPTION_REPUBLIC_STANDARD"
									autoresize = yes
									align = center
									parentanchor = center
									position = { 0 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								name = "Government Overview Header Tribal"
								size = { 290 40 }
								visible = "[GovernmentView.GetPlayer.GetGovernment.IsTribal]"
								blockoverride "Icon" { }
								textbox = {
									text = "RULER_TERM_DESCRIPTION_TRIBAL"
									autoresize = yes
									align = center
									parentanchor = center
									position = { 0 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								size = { 280 40 }
								blockoverride "Icon" { 
									size = { 32 32 }
									parentanchor = left
									texture = "gfx/interface/icons/font_icons/font_icon_civic.dds"
								}
								textbox = {
									text = "[GovernmentView.GetPlayer.GetGovernment.GetName]"
									autoresize = yes
									align = right
									parentanchor = right|vcenter
									position = { -10 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								size = { 110 40 }
								visible = "[GovernmentView.GetPlayer.GetGovernment.IsRepublic]"
								tooltip = "[GovernmentView.GetPlayer.GetSenateApprovalTooltip]"
								blockoverride "Icon" { 
									size = { 32 32 }
									parentanchor = left
									icon = {
										size = { 100% 100% }
										framesize = { 42 42 }
										frame = 1
										texture = "gfx/interface/diplomacy/icon_senate_approval.dds"
										visible = "[GreaterThanOrEqualTo_CFixedPoint( GovernmentView.GetPlayer.GetSenateApproval, '(CFixedPoint)50' )]"
									}
									icon = {
										size = { 100% 100% }
										framesize = { 42 42 }
										frame = 2
										texture = "gfx/interface/diplomacy/icon_senate_approval.dds"
										visible = "[LessThan_CFixedPoint( GovernmentView.GetPlayer.GetSenateApproval, '(CFixedPoint)50' )]"
									}
								}
								textbox = {
									text = "[GovernmentView.GetPlayer.GetSenateApproval|2]"
									autoresize = yes
									align = right
									parentanchor = right|vcenter
									position = { -10 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								size = { 110 40 }
								visible = "[Or(Player.GetGovernment.IsMonarchy, Player.GetGovernment.IsTribal)]"
								tooltip = "[GovernmentView.GetPlayer.GetRuler.GetPopularityToolTip]"
								blockoverride "Icon" { 
									size = { 32 32 }
									parentanchor = left
									using = icon_popularity
								}
								textbox = {
									text = "[GovernmentView.GetPlayer.GetRuler.GetPopularity|/0]"
									autoresize = yes
									align = right
									parentanchor = right|vcenter
									position = { -10 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								size = { 110 40 }
								visible = "[Player.GetGovernment.IsMonarchy]"
								tooltip = "[GovernmentView.GetPlayer.GetLegitimacyTooltip]"
								blockoverride "Icon" { 
									size = { 32 32 }
									parentanchor = left
									using = icon_legitimacy
								}
								textbox = {
									text = "[GovernmentView.GetPlayer.GetLegitimacy|/0]%"
									autoresize = yes
									align = right
									parentanchor = right|vcenter
									position = { -10 -2 }
									using = BaseFontM
									using = Default_FontColor
								}
							}
							icon_card = {
								size = { 180 40 }
								visible = "[GovernmentView.GetPlayer.GetGovernment.IsRepublic]"
								tooltip = "[GovernmentView.GetTermDurationInfo]"
								blockoverride "Icon" {
									size = { 32 32 }
									position = { 0 1 }
									parentanchor = left
									texture = "gfx/interface/icons/shared_icons/time.dds"
								}
								fixed_size_progressbar = {
									parentanchor = vcenter|right
									position = { -10 0 }
									blockoverride "size" { size = { 130 10 } }
									blockoverride "Value" { value = "[GovernmentView.GetTermDuration]" }									
								}
							}
						}
					}
					flowcontainer = {
						parentanchor = hcenter
						spacing = 5
						ignoreinvisible = yes
						widget = { #Republic
							size = { 190 220 }
							parentanchor = bottom
							visible = "[GovernmentView.GetPlayer.GetGovernment.IsRepublic]"
							using = background_widget
							blockoverride "Margin" { margin = { 2 2 } }
							flowcontainer = {
								direction = vertical
								flowcontainer = {
									datacontext = "[GovernmentView.GetPlayer.GetRuler]"
									direction = vertical
									margin = { 5 5 }
									spacing = 10
									parentanchor = hcenter
									icon_and_text = {
										name = "Popularity"
										size = { 120 32 }
										blockoverride "Icon" { using = icon_popularity }
										blockoverride "Text" { text = "[Character.GetPopularity|/0]" }
										tooltip = "[Character.GetPopularityToolTip]"
									}
									icon_and_text = {
										name = "Corruption"
										alpha = "[TransparentIfZero(Character.GetCorruption)]"
										size = { 120 32 }
										blockoverride "Icon" { using = icon_corruption }
										blockoverride "Text" { text = "[Character.GetCorruption|/0]" }
										tooltip = "[Character.GetCorruptionToolTip]"
									}
								}
								margin_widget = {
									size = { 190 37 }
									margin = { 5 5 }
									sub_header = {
										size = { 180 32 }
										blockoverride "Title_text"
										{
											text = "NEXT_RULER_TEXT"
											tooltip = "NEXT_RULER_TT_REPUB"
										}
									}
								}
								flowcontainer = {
									datacontext = "[GovernmentView.GetPlayer.GetSuccession.GetPrimaryHeir]"
									visible = "[Character.IsValid]"
									margin = { 5 5 }
									spacing = 5
									cpt_button = {
										size = { 60 90 }
									}
									flowcontainer = {
										direction = vertical
										spacing = 10
										icon_card = {
											size = { 110 40 }
											tooltip = "[Character.GetSuccessionScoreInfo]"
											blockoverride "Icon" { 
												size = { 32 32 }
												parentanchor = left
												texture = "[GetPartyIcon(GovernmentView.GetNextParty)]"
											}
											textbox = {
												text = "[Character.GetSuccessionScore|0]"
												autoresize = yes
												align = right
												parentanchor = right|vcenter
												position = { -10 0 }
												using = BaseFontM
												using = Default_FontColor
											}
										}
										icon_and_text = {
											size = { 110 32 }
											parentanchor = hcenter
											blockoverride "Icon" { using = icon_power_base }
											blockoverride "Text" { text = "[Character.GetPowerBase|/0]" }
											tooltip = "[Character.GetPowerBaseInfo]"
										}
									}
								}
							}
						}
						widget = { #Monarchy
							size = { 190 220 }
							parentanchor = bottom
							visible = "[GovernmentView.GetPlayer.GetGovernment.IsMonarchy]"
							using = background_widget
							blockoverride "Margin" { margin = { 2 2 } }
							flowcontainer = {
								direction = vertical
								flowcontainer = {
									direction = vertical
									margin = { 5 5 }
									spacing = 10
									parentanchor = hcenter
									flowcontainer = {
										datacontext = "[GovernmentView.GetPlayer.GetRuler]"
										spacing = 10
										icon_and_text = {
											name = "Corruption"
											alpha = "[TransparentIfZero(Character.GetCorruption)]"
											size = { 80 32 }
											blockoverride "Icon" { using = icon_corruption }
											blockoverride "Text" { text = "[Character.GetCorruption|/0]" }
											tooltip = "[Character.GetCorruptionToolTip]"
										}
										icon_and_text = {
											size = { 80 32 }
											blockoverride "Icon" { using = icon_power_base }
											blockoverride "Text" { text = "[Character.GetPowerBase|/0]" }
											tooltip = "[Character.GetPowerBaseInfo]"
										}
									}
								}
								margin_widget = {
									size = { 190 37 }
									margin = { 5 5 }
									sub_header = {
										size = { 180 32 }
										blockoverride "Title_text"
										{
											text = "SUCCESSION"
											tooltip = "[GovernmentView.GetLegitimacyTooltip]"
										}
									}
								}
								flowcontainer = {
									datacontext = "[GovernmentView.GetPlayer.GetSuccession.GetPrimaryHeir]"
									visible = "[Character.IsValid]"
									margin = { 5 5 }
									spacing = 5
									cpt_button = {
										size = { 60 90 }
									}
									flowcontainer = {
										direction = vertical
										spacing = 10
										icon_card = {
											size = { 110 40 }
											tooltip = "[Character.GetSuccessionScoreInfo]"
											blockoverride "Icon" { 
												size = { 32 32 }
												parentanchor = left
												texture = "gfx/interface/icons/shared_icons/leader.dds"
											}
											textbox = {
												text = "[Character.GetSuccessionScore|0]"
												autoresize = yes
												align = right
												parentanchor = right|vcenter
												position = { -10 0 }
												using = BaseFontM
												using = Default_FontColor
											}
										}
										icon_and_text = {
											size = { 110 32 }
											parentanchor = hcenter
											blockoverride "Icon" { using = icon_loyalty }
											blockoverride "Text" { text = "[Character.GetLoyalty|0]" }
											tooltip = "[Character.GetLoyaltyToolTip]"
										}
										icon_and_text = {
											size = { 110 32 }
											parentanchor = hcenter
											blockoverride "Icon" { texture = "gfx/interface/icons/modifiers/max_friends.dds" }
											blockoverride "Text" { text = "[Character.GetNumOfSupportsAsHeir]" }
											tooltip = "[Character.GetHeirSupportInformation]"
										}
									}
								}
							}
						}
						widget = { #Tribal
							size = { 190 178 }
							parentanchor = bottom
							visible = "[GovernmentView.GetPlayer.GetGovernment.IsTribal]"
							using = background_widget
							blockoverride "Margin" { margin = { 2 2 } }
							flowcontainer = {
								direction = vertical
								flowcontainer = {
									datacontext = "[GovernmentView.GetPlayer.GetRuler]"
									direction = vertical
									margin = { 5 5 }
									spacing = 10
									parentanchor = hcenter
									icon_and_text = {
										name = "Corruption"
										alpha = "[TransparentIfZero(Character.GetCorruption)]"
										size = { 120 32 }
										blockoverride "Icon" { using = icon_corruption }
										blockoverride "Text" { text = "[Character.GetCorruption|/0]" }
										tooltip = "[Character.GetCorruptionToolTip]"
									}
								}
								margin_widget = {
									size = { 190 37 }
									margin = { 5 5 }
									sub_header = {
										size = { 180 32 }
										blockoverride "Title_text"
										{
											text = "NEXT_RULER_TEXT"
											tooltip = "NEXT_RULER_TT_MONARCHY"
										}
									}
								}
								flowcontainer = {
									datacontext = "[GovernmentView.GetPlayer.GetSuccession.GetPrimaryHeir]"
									visible = "[Character.IsValid]"
									margin = { 5 5 }
									spacing = 5
									cpt_button = {
										size = { 60 90 }
									}
									flowcontainer = {
										direction = vertical
										spacing = 10
										icon_card = {
											size = { 110 40 }
											tooltip = "[Character.GetSuccessionScoreInfo]"
											blockoverride "Icon" { 
												size = { 32 32 }
												parentanchor = left
												texture = "gfx/interface/icons/shared_icons/leader.dds"
											}
											textbox = {
												text = "[Character.GetSuccessionScore|0]"
												autoresize = yes
												align = right
												parentanchor = right|vcenter
												position = { -10 0 }
												using = BaseFontM
												using = Default_FontColor
											}
										}
										icon_and_text = {
											size = { 110 32 }
											parentanchor = hcenter
											blockoverride "Icon" { using = icon_loyalty }
											blockoverride "Text" { text = "[Character.GetLoyalty|0]" }
											tooltip = "[Character.GetLoyaltyToolTip]"
										}
									}
								}
							}
						}
						widget = {
							size = { 220 232 }
							datacontext = "[GovernmentView.GetPlayer.GetRuler]"
							using = background_widget
							blockoverride "Margin" { margin = { 2 2 } }
							flowcontainer = {
								direction = vertical
								margin_widget = {
									size = { 220 47 }
									margin = { 5 5 }
									sub_header = {
										size = { 210 32 }
										blockoverride "Title_text"
										{
											text = "[GovernmentView.GetPlayer.GetRulerTitle]"
											tooltip = "RULER_TITLE_TT"
										}
									}
								}
								flowcontainer = {
									portrait_button = {
										name = "rulerpic"
										size = { 130 195 }
										using = pt_button_large
										pop_out = yes
										portrait_texture = "[Character.GetPortrait('default', 'looking_right')]"
									}
									flowcontainer = {
										direction = vertical
										spacing = 10
										margin_top = 15
										icon_and_text = { #military
											#visible = "[GreaterThanOrEqualTo_int32( GovernmentView.GetPlayer.GetRuler.GetMartial, GovernmentView.GetPlayer.GetCoRuler.GetMartial )]"
											size = { 80 32 }
											blockoverride "Icon" { using = icon_military }
											blockoverride "Text" { text = "[Character.GetMartial]" }
