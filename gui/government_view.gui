		flowcontainer = {
			name = "Grand Council tab"
			margin = { 10 0 }
			direction = vertical
			# [grand-council-tab] Qing-only 4th tab. Driven by the qing_gc_tab GUI var
			# (no 4th native GovernmentView tab exists); mirrors economy_view.gui's
			# sub-tab idiom. Rosters read country-held vars/lists cached by
			# se_QING_COUNCIL.txt; interactive appoint/seat verbs live in
			# QING_governance_actions.txt. The moved "Grand Council Edicts" strip
			# (formerly "Statecraft of the Great Qing") sits at the bottom.
			visible = "[GetVariableSystem.HasValue('qing_gc_tab', 'grand_council')]"
			scrollarea = {
				size = { 970 790 }
				scrollbarpolicy_horizontal = always_off
				scrollbar_vertical = { using = VerticalScrollBar }
				scrollwidget = {
					flowcontainer = {
						direction = vertical
						spacing = 6
						margin = { 8 6 }
						sub_header = {
							size = { 950 32 }
							blockoverride "Title_text" { text = "QING_GC_HEADER_ROSTER" }
						}
						widget = {
							size = { 950 44 }
							using = background_widget
							blockoverride "Margin" { margin = { 2 2 } }
							flowcontainer = {
								spacing = 26
								margin = { 12 6 }
								icon_and_text = {
									size = { 150 30 }
									blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/senate_seat.dds" }
									blockoverride "Text" { text = "[GovernmentView.GetPlayer.MakeScope.Var('qing_council_filled_count').GetValue|0] / 13" }
									tooltip = "QING_GC_SEATS_TT"
								}
								# [#314 boot-test Bug2] council effectiveness was shown TWICE (a bare number AND a
								# bar). Removed the standalone number; the bar alone carries it, with the exact value
								# in the hover tooltip (QING_GC_EFFECTIVENESS_TT now leads with "Council Effectiveness:
								# [value]/100."). qing_council_effectiveness is a 0..100 player-scope var; the S-bar Value
								# wants a 0..1 fraction, so scale by 0.01 via the proven Multiply_CFixedPoint idiom.
								icon_and_text_progress_S = {
									blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/civic.dds" }
									blockoverride "Text" { text = "" }
									blockoverride "Value" { value = "[FixedPointToFloat( Multiply_CFixedPoint( GovernmentView.GetPlayer.MakeScope.GetVariable('qing_council_effectiveness').GetValue, '(CFixedPoint)0.01' ) )]" }
									tooltip = "QING_GC_EFFECTIVENESS_TT"
								}
								icon_and_text = {
									size = { 190 30 }
									blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/diplomacy.dds" }
									# [#308 D] three-way 滿 / 漢 / 其他 (Manchu / Han / Other) ethnic split.
										blockoverride "Text" { text = "[GovernmentView.GetPlayer.MakeScope.Var('qing_council_manchu_count').GetValue|0] / [GovernmentView.GetPlayer.MakeScope.Var('qing_council_han_count').GetValue|0] / [GovernmentView.GetPlayer.MakeScope.Var('qing_council_other_count').GetValue|0]" }
									tooltip = "QING_GC_BALANCE_TT"
								}
								# [#267 develop] "Titles Unassigned" alert. Shown only when at least one of the 11
								# appointable great offices is vacant, driven off the same qing_council_vacancy count
								# (0..11) that se_QING_COUNCIL.txt derives for the effectiveness vacancy penalty — so
								# the badge and the penalty can never disagree. Hidden entirely when the council is full.
								icon_and_text = {
									size = { 210 30 }
									visible = "[GreaterThanOrEqualTo_CFixedPoint( GovernmentView.GetPlayer.MakeScope.GetVariable('qing_council_vacancy').GetValue, '(CFixedPoint)1' )]"
									blockoverride "Icon" { texture = "gfx/interface/base_parts/alert_a.dds" }
									blockoverride "Text" { text = "QING_GC_TITLES_UNASSIGNED" }
									tooltip = "QING_GC_TITLES_UNASSIGNED_TT"
								}
							}
						}
							# [dynastic-seats #115/#116] The Throne (大統): the PERMANENT seats — Emperor
							# 皇帝 (always current_ruler) and Crown Prince 皇太子 (primary_heir) — plus the
							# Grand Regent 攝政, shown only while a regency is in force. Read-only cards
							# (no appoint/vacate: these are filled by blood and by regency event, not by
							# the player). Mirrors the office-card idiom; se_QING_SEATS.txt maintains the vars.
							sub_header = {
								size = { 950 32 }
								blockoverride "Title_text" { text = "QING_GC_HEADER_DYNASTY" }
							}

							widget = {
								size = { 950 178 }
								flowcontainer = {
									spacing = 0
								widget = {
									size = { 312 168 }
									margin = { 3 3 }
									datacontext = "[GovernmentView.GetPlayer.MakeScope.Var('qing_office_emperor_holder').GetCharacter]"
									using = background_widget
									blockoverride "Margin" { margin = { 2 2 } }
									flowcontainer = {
										direction = vertical
										margin = { 5 4 }
										spacing = 3
										ignoreinvisible = yes # [develop #244] hidden FILLED/VACANT branch must not reserve card height
										textbox = {
											using = BaseFontS
											using = Default_FontColor
											size = { 290 24 }
											text = "QING_GC_EMPEROR"
										}
										flowcontainer = {
											spacing = 6
											visible = "[GovernmentView.GetPlayer.MakeScope.Var('qing_office_emperor_holder').IsSet]"
											# [BT-26] portrait with the statesmanship bar stacked UNDER it (was at the foot of the name/skills
											# column, overrunning the card). Bar now sits beneath the portrait, to the left of the 2x2 skills.
											flowcontainer = {
												direction = vertical
												spacing = 3
												cpt_button = { size = { 46 60 } }
												flowcontainer = {
													visible = "[GovernmentView.GetPlayer.MakeScope.Var('qing_office_emperor_holder').IsSet]"
													icon_and_text_progress_S = {
														blockoverride "Icon" { using = icon_statesmanship }
														blockoverride "Text" { text = "[Character.GetExperience|1]%" }
														blockoverride "Value" { value = "[FixedPointToFloat( Character.GetExperience )]" }
														tooltip = "QING_GC_STATESMANSHIP_TT"
													}
												}
											}
											# [#308/user] the Emperor's Imperial Favor square is always MAX GREEN (the throne is
											# in perfect favour with itself), plus a FACTION square for the faction he anchors.
											qing_favor_square_max = { }
											qing_faction_square = { }
											flowcontainer = {
												direction = vertical
												spacing = 3
												tag = { text = "[Character.GetName]"  maximumsize = { 210 26 }  using = BaseFontS  using = Default_FontColor }
												icon_and_text = {
													size = { 100 28 }
													blockoverride "Icon" { texture = "gfx/interface/icons/shared_icons/loyalty.dds" }
													blockoverride "Text" { text = "[Character.GetLoyalty|0]" }
													tooltipwidget = { using = character_loyalty_tooltip }
												}
												# [#260] figurehead statesmanship = the full 4-skill line (emperor is judged on ALL
												# competences, not one office skill). Mirrors the summit-card 4-attribute row; read-only
												# existing character data (no accrual mechanic, per the #260 spec).
												# [Bug1-review] a 4-wide single row overflows this ~190px throne column (icon_and_text
												# has 48px fixed chrome, so a 2-digit value needs ~62px+ and 4 of them exceed the card),
												# so lay the 4 skills out 2x2 — each cell then fits its number instead of eliding to "....".
												# Office cards (350px+ wide) keep their single-row 78px form.
												flowcontainer = {
													direction = vertical
													spacing = 3
													flowcontainer = {
														spacing = 4
														icon_and_text = { size = { 88 24 }  blockoverride "Icon" { using = icon_military }   blockoverride "Text" { text = "[Character.GetMartial]" }   tooltip = "[Character.GetMartialToolTip]" }
														icon_and_text = { size = { 88 24 }  blockoverride "Icon" { using = icon_civic }      blockoverride "Text" { text = "[Character.GetFinesse]" }   tooltip = "[Character.GetFinesseToolTip]" }
													}
													flowcontainer = {
														spacing = 4
														icon_and_text = { size = { 88 24 }  blockoverride "Icon" { using = icon_oratory }    blockoverride "Text" { text = "[Character.GetCharisma]" }  tooltip = "[Character.GetCharismaToolTip]" }
														icon_and_text = { size = { 88 24 }  blockoverride "Icon" { using = icon_religious }  blockoverride "Text" { text = "[Character.GetZeal]" }      tooltip = "[Character.GetZealToolTip]" }
													}
												}

											}
										}
										textbox = {
